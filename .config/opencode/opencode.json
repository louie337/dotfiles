{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": false,
	"mcp": {
		"chrome-devtools": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"chrome-devtools-mcp@latest"
			],
			"enabled": true,
		}
	},
	"permission": {
		"bash": {
			"*": "allow",
			"git add *": "ask",
			"git commit *": "ask",
			"git stash *": "allow",
			"git push *": "deny"
		}
	},
	"agent": {
		"build": {
			"model": "openai/gpt-5.5"
		},
		"plan": {
			"model": "openai/gpt-5.5",
			"color": "#FF6B6B",
			"permission": {
				"eidt": "deny"
			}
		},
		"teach": {
			"color": "#2FACED"
		},
		"patch": {
			"color": "#FFD966"
		},
		"compaction": {},
	},
	"provider": {
		"openai": {
			"name": "Datax OpenAI",
			"options": {
				"baseURL": "https://sg.datax.io/v1",
				"apiKey": "{env:DATAX_OPENAI_API_KEY}"
			},
			"models": {
				"gpt-5.5": {
					"limit": {
						"context": 400000,
						"input": 272000,
						"output": 128000
					}
				}
			}
		},
	},
	"plugin": [
		"@mohak34/opencode-notifier@latest"
	],
	"small_model": "opencode/big-pickle",
}
