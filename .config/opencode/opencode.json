{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": false,
	"mcp": {
		"chrome-devtools": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"chrome-devtools-mcp@latest"
			],
			"enabled": true,
		},
		"mobile-mcp": {
			"type": "local",
			"command": [
				"npx",
				"@mobilenext/mobile-mcp@latest"
			],
			"enabled": true
		}
	},
	"permission": {
		"bash": {
			"*": "allow",
			"git add *": "ask",
			"git commit *": "ask",
			"git stash *": "ask",
			"git push *": "deny"
		}
	},
	"agent": {
		"build": {
			"model": "github-copilot/claude-sonnet-4.6"
		},
		"plan": {
			"model": "github-copilot/claude-sonnet-4.6",
			"color": "#FF6B6B"
		},
		"teach": {
			"color": "#2FACED"
		},
		"patch": {
			"color": "#FFD966"
		},
		"compaction": {
			"model": "github-copilot/gpt-5-mini"
		},
	},
	"plugin": [
		"@mohak34/opencode-notifier@latest"
	]
}
