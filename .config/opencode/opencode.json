{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"chrome-devtools": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"chrome-devtools-mcp@latest"
			],
			"enabled": true,
		}
	},
	"agent": {
		"compaction": {
			"model": "github-copilot/gpt-5-mini"
		}
	},
	"plugin": [
		"@mohak34/opencode-notifier@latest"
	]
}
